@page "/history"
@using System
@using System.Linq
@inject NavigationManager Navigation
@inject ILogger<History> Logger
@inject BackendApiService ApiService
@rendermode InteractiveServer


<link href="_content/Blazor.Bootstrap/blazor.bootstrap.css" rel="stylesheet" />

<PageTitle>History</PageTitle>

    <div class="history-controls">
        <a class="Home Button" href="/">Back</a>
        <input class="search-input" placeholder="Search by file name, piece mark, or project (you can also type a date like 12/11/2025)..." @bind="searchTerm" @bind:event="oninput" />
        <button class="btn btn-sm btn-secondary" type="button" @onclick="ClearSearch">Clear</button>
        <div class="export-dropdown @(IsAnySelected ? "" : "disabled")" style="margin-left:8px;">
            <button type="button" class="ViewButton export-toggle" aria-haspopup="menu" disabled="@(!IsAnySelected)" aria-disabled="@(!IsAnySelected)">Export Selected </button>
            <div class="export-list" role="menu">
                <ul>
                    <li role="none"><button role="menuitem" class="dropdown-item" type="button" @onclick="() => BatchExport(true)">Export Selected JSON</button></li>
                    <li role="none"><button role="menuitem" class="dropdown-item" type="button" @onclick="() => BatchExport(false)">Export Selected CSV</button></li>
                </ul>
            </div>
        </div>
    </div>

<div class="page-wrapper">
    @if (history == null || history.Count == 0)
    {
        <p>No history available.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th style="width:38px"><input type="checkbox" @onclick="ToggleSelectAll" /></th>
                    <th>#</th>
                    <th>File Name</th>
                    <th>Pages</th>
                    <th>Piece Mark</th>
                    <th>Project</th>
                    <th>Date Processed</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in DisplayItems.Select((di, displayIndex) => new { di.ticket, di.historyIndex, displayIndex }))
                {
                    <tr>
                        <td><input type="checkbox" checked="@IsSelected(item.historyIndex)" @onchange="(e) => ToggleSelect(item.historyIndex, e)" /></td>
                        <td>@(item.displayIndex + 1)</td>
                        <td>@item.ticket.FileName</td>
                        <td>@item.ticket.NumberOfPages</td>
                        <td>@item.ticket.FileNamePieceMark</td>
                        <td>@item.ticket.ProjectName</td>
                        <td>@item.ticket.dateTimeExtracted</td>
                        <td>
                            <button class = "ViewButton" @onclick="() => OpenTicket(item.historyIndex)">View</button>
                                <div class="export-dropdown">
                                    <button type="button" class="ViewButton export-toggle" aria-haspopup="menu" aria-expanded="false">Export </button>
                                    <div class="export-list" role="menu">
                                        <ul>
                                            <li role="none"><button role="menuitem" class="dropdown-item" type="button" @onclick="() => HandleExportClick(true, item.historyIndex)">Export JSON <span class="hint">.json</span></button></li>
                                            <li role="none"><button role="menuitem" class="dropdown-item" type="button" @onclick="() => HandleExportClick(false, item.historyIndex)">Export CSV <span class="hint">.csv</span></button></li>
                                        </ul>
                                    </div>
                                </div>
                            <button class = "RemoveButton" @onclick="() => DeleteTicket(item.displayIndex)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {

    private List<dynamic> history = new List<dynamic>();
    private string searchTerm = string.Empty;

    private IEnumerable<dynamic> FilteredHistory
    {
        get
        {
            var q = history.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                var term = searchTerm.Trim();
                q = q.Where(t =>
                    (t?.fileName ?? string.Empty).ToString().Contains(term, StringComparison.OrdinalIgnoreCase)
                    || (t.FileNamePieceMark ?? string.Empty).Contains(term, StringComparison.OrdinalIgnoreCase)
                    || (t.ProjectName ?? string.Empty).Contains(term, StringComparison.OrdinalIgnoreCase)
                    || (t.dateTimeExtracted.ToString() ?? string.Empty).Contains(term, StringComparison.OrdinalIgnoreCase)
                );
            }
            return q;
        }
    }

    // Display items map the filtered ticket to its original history index
    private IEnumerable<(dynamic ticket, int historyIndex)> DisplayItems
    {
        get
        {
            return FilteredHistory.Select((t, idx) => (ticket: t, historyIndex: idx)).Cast<(dynamic, int)>();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // Load history from API
        var historyData = await ApiService.GetHistoryAsync();
        if (historyData != null)
        {
            history = historyData.Cast<dynamic>().ToList();
        }
        StateHasChanged();
    }

    private void ClearSearch()
    {
        searchTerm = string.Empty;

    }

    private void OpenTicket(int index)
    {
        // Navigate to processing page with history ticket ID
        if (index >= 0 && index < history.Count)
        {
            Navigation.NavigateTo($"/processing?historyIndex={index}");
        }
    }

    private void DeleteTicket(int index)
    {
        // Note: Delete functionality would need to be implemented in the Backend API
        // For now, this is a placeholder
    }

    private void HandleExportClick(bool val, int index){
        var valString = val.ToString().ToLower();
        Navigation.NavigateTo($"/export/{valString}/{index}", forceLoad: true);
    }

    // Selection state for batch export
    private HashSet<int> selectedIndices = new HashSet<int>();

    private bool IsAnySelected => selectedIndices != null && selectedIndices.Count > 0;

    private bool IsSelected(int index) => selectedIndices.Contains(index);

    private void ToggleSelect(int index, ChangeEventArgs e)
    {
        bool now = false;
        if (e?.Value is bool b)
            now = b;
        else if (e?.Value is string s && bool.TryParse(s, out var parsed))
            now = parsed;

        if (now)
            selectedIndices.Add(index);
        else
            selectedIndices.Remove(index);
    }

    private void ToggleSelectAll()
    {
        var all = DisplayItems.Select(di => di.historyIndex).ToList();
        bool anyNotSelected = all.Any(i => !selectedIndices.Contains(i));
        if (anyNotSelected)
        {
            foreach (var i in all) selectedIndices.Add(i);
        }
        else
        {
            foreach (var i in all) selectedIndices.Remove(i);
        }
    }

    private void BatchExport(bool isJson)
    {
        if (selectedIndices == null || selectedIndices.Count == 0)
        {
            // nothing selected — no-op for now
            return;
        }

        var ids = string.Join(',', selectedIndices.OrderBy(i => i));
        var url = $"/export/batch/{isJson}?ids={ids}";
        Navigation.NavigateTo(url, forceLoad: true);
    }

}
