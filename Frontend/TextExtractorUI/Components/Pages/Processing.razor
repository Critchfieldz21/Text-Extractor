@page "/processing"
@using BlazorBootstrap
@using Microsoft.AspNetCore.WebUtilities
@using System.Linq
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject BackendApiService ApiService
<link href="_content/Blazor.Bootstrap/blazor.bootstrap.css" rel="stylesheet" />
<script src="_content/Blazor.Bootstrap/blazor.bootstrap.js"></script>

<PageTitle>PDF Info</PageTitle>

<section class="topbar">
    <button class="homeButt" type="button" @onclick="GoHome">Back to Home</button>
    <button class="historyButt" type="button" @onclick="GoHistory">History</button>
    <button class="navbtn" type="button" @onclick="GoLeft">←</button>
    <button class="navbtn" type="button" @onclick="GoRight">→</button>
</section>

<section>
    <div class="titleName">
        <h1>PDF Info: <span class="pdf-name" title="@setName()">@setName()</span></h1>
    </div>
</section>

<section class="pdf-processing-container">
    <!-- PDF Viewer -->
    <div class="pdfVisBox">
        @if (!string.IsNullOrEmpty(base64Url))
        {
            <PdfViewer @key="base64Url" Class="pdfViewer" Url="@base64Url" OnDocumentLoaded="OnDocumentLoaded"
                OnPageChanged="OnPageChanged" />
        }
        else
        {
            <p><em>No PDF data available to display.</em></p>
        }
    </div>
    <!-- PDF Info -->
    <div class="pdfinfo">
        <div class="pdfinfo-content">
        <h4 class="pdfinfo-subtitle">Details</h4>
        <table class="info-table">
            @if (ticket != null)
            {
                <tr><th>FileName</th><td>@ticket.fileName</td></tr>
                <tr><th>ProcessedDate</th><td>@ticket.processedDate</td></tr>
                <tr><th>NumberOfPages</th><td>@ticket.numberOfPages</td></tr>
                <tr><th>PageNames</th><td>@ticket.pageNames</td></tr>
                <tr><th>ProjectNumber</th><td>@ticket.projectNumber</td></tr>
                <tr><th>ProjectName</th><td>@ticket.projectName</td></tr>
                <tr><th>ControlNumbers</th><td>@ticket.controlNumbers</td></tr>
                <tr><th>PiecesRequired</th><td>@ticket.piecesRequired</td></tr>
                <tr><th>Weight</th><td>@ticket.weight</td></tr>
                <tr><th>DesignNumber</th><td>@ticket.designNumber</td></tr>
            }
        </table>

        <h3 class="pdfinfo-title">Form View</h3>
        <table class="info-table">
            @if (ticket != null)
            {
                <tr><th>RectanglePage</th><td>@ticket.rectanglePage</td></tr>
                <tr><th>FormViewRectangleX</th><td>@ticket.formViewRectangleX</td></tr>
                <tr><th>FormViewRectangleY</th><td>@ticket.formViewRectangleY</td></tr>
                <tr><th>FormViewRectangleWidth</th><td>@ticket.formViewRectangleWidth</td></tr>
                <tr><th>FormViewRectangleHeight</th><td>@ticket.formViewRectangleHeight</td></tr>
            }
        </table>

        <h3 class="pdfinfo-title" >Section View</h3>
        <table class="info-table">
            @if (ticket != null)
            {
                <tr><th>SectionViewRectangleX</th><td>@ticket.sectionViewRectangleX</td></tr>
                <tr><th>SectionViewRectangleY</th><td>@ticket.sectionViewRectangleY</td></tr>
                <tr><th>SectionViewRectangleWidth</th><td>@ticket.sectionViewRectangleWidth</td></tr>
                <tr><th>SectionViewRectangleHeight</th><td>@ticket.sectionViewRectangleHeight</td></tr>
            }
        </table>
        <img src="../NortheastPrecast.webp" />
        </div>
    </div>
</section>

@code {
    private string? base64Url;
    private int currTicketIndex = 0;
    private dynamic? ticket;
    private bool viewingHistory = false;

    protected override void OnInitialized()
    {
        // detect if a historyIndex query param was supplied and load from history
        try
        {
            var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
            var qp = QueryHelpers.ParseQuery(uri.Query);
            if (qp.TryGetValue("historyIndex", out var val))
            {
                if (int.TryParse(val.ToString(), out var idx) && idx >= 0)
                {
                    viewingHistory = true;
                    currTicketIndex = idx;
                }
            }
        }
        catch
        {
            // ignore parse errors and default to current tickets
        }

        // load the ticket from the appropriate source
        LoadTicket();
    }

    private void GoRight()
    {
        if (viewingHistory)
        {
            // History navigation would be handled differently with API
            // For now, just disable right arrow in history view
        }
        else
        {
            // Current tickets navigation would need local state
        }
    }

    private void GoLeft()
    {
         if (currTicketIndex > 0)
        {
            currTicketIndex--;
            LoadTicket();
        }
    }

    private string GetPDFInfo()
    {
        if (ticket == null) return "";
        return ticket.ToString().Replace("\n", "<br />");
    }

    private void LoadTicket()
    {
        // Since we're using API, ticket should be loaded from query param
        // This would need to be updated to load from API if needed
    }

    private string? setName()
    {
        return ticket?.fileName ?? "(no file)";
    }

    private void OnDocumentLoaded(PdfViewerEventArgs args) { }

    private void OnPageChanged(PdfViewerEventArgs args) { }

    private void GoHome()
    {
        currTicketIndex = 0;
        Navigation.NavigateTo("/");
    }

    private void GoHistory()
    {
        currTicketIndex = 0;
        Navigation.NavigateTo("/history");
    }
}