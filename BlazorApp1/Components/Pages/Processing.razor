@page "/processing"
@using BackendLibrary
@using BlazorBootstrap
@using Microsoft.AspNetCore.WebUtilities
@using System.Linq
@rendermode InteractiveServer
@inject ShopTicketService sTService
@inject NavigationManager Navigation
<link href="_content/Blazor.Bootstrap/blazor.bootstrap.css" rel="stylesheet" />
<script src="_content/Blazor.Bootstrap/blazor.bootstrap.js"></script>

<PageTitle>PDF Info</PageTitle>

<section class="topbar">
    <button class="homeButt" type="button" @onclick="GoHome">Back to Home</button>
    <button class="historyButt" type="button" @onclick="GoHistory">History</button>
    <button class="navbtn" type="button" @onclick="GoLeft">←</button>
    <button class="navbtn" type="button" @onclick="GoRight">→</button>
</section>

<section>
    <div class="titleName">
        <h1>PDF Info: <span class="pdf-name" title="@setName()">@setName()</span></h1>
    </div>
</section>

<section class="pdf-processing-container">
    <!-- PDF Viewer -->
    <div class="pdfVisBox">
        @if (!string.IsNullOrEmpty(base64Url))
        {
            <PdfViewer @key="base64Url" Class="pdfViewer" Url="@base64Url" OnDocumentLoaded="OnDocumentLoaded"
                OnPageChanged="OnPageChanged" />
        }
        else
        {
            <p><em>No PDF data available to display.</em></p>
        }
    </div>
    <!-- PDF Info -->
    <div class="pdfinfo">
        <div class="pdfinfo-content">
        <h4 class="pdfinfo-subtitle">Details</h4>
        <table class="info-table">
            @foreach (var kvp in ticket.ToExportDictionary(true).Where(k =>
                k.Key is "FileName" or "ProcessedDate" or "NumberOfPages" or "PageNames" or "FileNamePieceMark" or "ProjectNumber" or "ProjectName" or "FileContentPieceMark" or "ControlNumbers" or "PiecesRequired" or "Weight" or "DesignNumber"))
            {
                <tr>
                    <th>@kvp.Key</th>
                    <td>@kvp.Value</td>
                </tr>
            }
        </table>

        <h3 class="pdfinfo-title">Form View</h3>
        <table class="info-table">
            @foreach (var kvp in ticket.ToExportDictionary(true).Where(k =>
                k.Key is "RectanglePage" or "FormViewRectangleX" or "FormViewRectangleY" or "FormViewRectangleWidth" or "FormViewRectangleHeight"))
            {
                <tr>
                    <th>@kvp.Key</th>
                    <td>@kvp.Value</td>
                </tr>
            }
        </table>

        <h3 class="pdfinfo-title" >Section View</h3>
        <table class="info-table">
            @foreach (var kvp in ticket.ToExportDictionary(true).Where(k =>
                k.Key is "SectionViewRectangleX" or "SectionViewRectangleY" or "SectionViewRectangleWidth" or "SectionViewRectangleHeight"))
            {
                <tr>
                    <th>@kvp.Key</th>
                    <td>@kvp.Value</td>
                </tr>
            }
        </table>
        <img src="../NortheastPrecast.webp" />
        </div>
    </div>
</section>

@code {
    private string? base64Url;
    private int currTicketIndex = 0;
    private ShopTicket? ticket;
    private bool viewingHistory = false;

    protected override void OnInitialized()
    {
        // detect if a historyIndex query param was supplied and load from history
        try
        {
            var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
            var qp = QueryHelpers.ParseQuery(uri.Query);
            if (qp.TryGetValue("historyIndex", out var val))
            {
                if (int.TryParse(val.ToString(), out var idx) && idx >= 0)
                {
                    viewingHistory = true;
                    currTicketIndex = idx;
                }
            }
        }
        catch
        {
            // ignore parse errors and default to current tickets
        }

        // load the ticket from the appropriate source
        LoadTicket();
    }

    private void GoRight()
    {
        if (viewingHistory)
        {
            if (currTicketIndex < sTService.HistorySize() - 1)
            {
                currTicketIndex++;
                LoadTicket();
            }
        }
        else
        {
            if (currTicketIndex < sTService.Size - 1)
            {
                currTicketIndex++;
                LoadTicket();
            }
        }
    }

    private void GoLeft()
    {
         if (currTicketIndex > 0)
        {
            currTicketIndex--;
            LoadTicket();
        }
    }

    private string GetPDFInfo()
    {
        if (viewingHistory)
        {
            var t = sTService.GetHistoryTicket(currTicketIndex + 1);
            return (t != null ? t.ToString() : "").Replace("\n", "<br />");
        }
        var ct = sTService.GetTicket(currTicketIndex + 1);
        return (ct != null ? ct.ToString() : "").Replace("\n", "<br />");
    }

    private void LoadTicket(){
        if (viewingHistory)
        {
            ticket = sTService.GetHistoryTicket(currTicketIndex + 1);
        }
        else
        {
            ticket = sTService.GetTicket(currTicketIndex + 1);
        }

        if (ticket?.PdfBytes != null && ticket.PdfBytes.Length > 0)
        {
            string pdfBase64 = Convert.ToBase64String(ticket.PdfBytes);
            base64Url = $"data:application/pdf;base64,{pdfBase64}";
        }
        else
        {
            base64Url = null;
        }
    }

    private string? setName(){
        if (viewingHistory)
        {
            var t = sTService.GetHistoryTicket(currTicketIndex + 1);
            return t?.FileName ?? "(no file)";
        }
        return ticket?.FileName ?? "(no file)";
    }

    private void OnDocumentLoaded(PdfViewerEventArgs args) { }

    private void OnPageChanged(PdfViewerEventArgs args) { }

    private void GoHome(){
        currTicketIndex = 0;
        Navigation.NavigateTo("/");
    }
    private void GoHistory(){
        currTicketIndex = 0;
        Navigation.NavigateTo("/history");
    }
}