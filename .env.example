# Vercel Environment Variables Template
# Copy this file to .env.local and fill in your values

# Backend Service URL (for Frontend to call)
BACKEND_URL=http://localhost:5000

# Frontend Service URL (for CORS configuration)
FRONTEND_URL=http://localhost:3000

# Database Configuration (if migrating from SQLite)
# DATABASE_URL=postgresql://user:password@host:port/database

# Feature Flags
ASPNETCORE_ENVIRONMENT=Production

# Optional: Model paths (if using external models)
# FORM_MODEL_PATH=/path/to/form_best.onnx
# SECTION_MODEL_PATH=/path/to/section_best.onnx

# Optional: File storage (if migrating to cloud storage)
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# S3_BUCKET=your_bucket

# Redis Cache (optional)
# REDIS_URL=redis://user:password@host:port
